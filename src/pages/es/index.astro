---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import AssessmentForm from '../../components/AssessmentForm.astro';
import ServicesGrid from '../../components/ServicesGrid.astro';
import { getMessages } from '../../i18n';

const locale = 'es' as const;
const t = getMessages(locale);
---

<BaseLayout locale={locale} path="/es/">
  <link slot="head" rel="preload" as="image" href="/videos/hero-poster.jpg" fetchpriority="high" />

  <div slot="header" class="hero-shell">
    <Header locale={locale} t={t} variant="dark" />
  </div>

  <Hero locale={locale} t={t} />

  <ServicesGrid
    locale={locale}
    eyebrow={t.services.eyebrow}
    title={t.services.title}
    lede={t.services.lede}
  />

  <AssessmentForm locale={locale} t={t} />

  <Footer slot="footer" locale={locale} t={t} />
</BaseLayout>

<style>
  .hero-shell {
    position: absolute;
    inset: 0 0 auto 0;
    z-index: 3;
  }
</style>
