---
export const prerender = true;
import ServicePage from '../../../components/ServicePage.astro';
import WebDesignServicePage from '../../../components/WebDesignServicePage.astro';
import { services } from '../../../data/services';

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const Page = service.slug === 'web-design-development' ? WebDesignServicePage : ServicePage;
---

<Page locale="es" service={service} />
