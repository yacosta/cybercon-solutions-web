---
import '../styles/global.css';
import interLatin400 from '@fontsource/inter/files/inter-latin-400-normal.woff2?url';
import soraLatin700 from '@fontsource/sora/files/sora-latin-700-normal.woff2?url';
import { getMessages, localePath } from '../i18n';
import { absoluteUrl, site } from '../lib/site';
import { breadcrumbJsonLd, jsonLdScript, organizationJsonLd, websiteJsonLd } from '../lib/seo';
import CookieBanner from '../components/CookieBanner.astro';
import Analytics from '../components/Analytics.astro';

interface Props {
  locale?: 'en' | 'es';
  title?: string;
  description?: string;
  path?: string;
  noindex?: boolean;
  ogType?: 'website' | 'article';
  breadcrumbs?: { name: string; path: string }[];
}

const {
  locale = 'en',
  title,
  description,
  path = '/',
  noindex = false,
  ogType = 'website',
  breadcrumbs,
} = Astro.props;

const t = getMessages(locale);
const pageTitle = title ?? t.meta.title;
const pageDescription = description ?? t.meta.description;
const canonical = absoluteUrl(path);
const normalizedPath = path.replace(/\/$/, '') || '/';
const is404Page = normalizedPath === '/404' || normalizedPath === '/es/404';
const enUrl = absoluteUrl(path.replace(/^\/es/, '') || '/');
const esUrl = absoluteUrl(path.startsWith('/es') ? path : path === '/' ? '/es/' : `/es${path}`);
const ogImage = absoluteUrl(site.ogImage);
const ogImageAlt =
  locale === 'es'
    ? `${site.name}: Tecnología, resuelta. Detectamos problemas a tiempo, con la seguridad como base.`
    : `${site.name}: Technology, handled. We catch issues early, with security as the baseline.`;
const twitterImageAlt =
  locale === 'es' ? `Marca de ${site.name}` : `${site.name} brand lockup`;
const htmlLang = locale === 'es' ? 'es' : 'en';

const structuredData = [
  organizationJsonLd(locale),
  websiteJsonLd(locale),
  ...(breadcrumbs?.length ? [breadcrumbJsonLd(breadcrumbs)] : []),
];
---

<!doctype html>
<html lang={htmlLang} dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0F2C4C" />
    <meta name="color-scheme" content="light" />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    )}
    <link rel="canonical" href={canonical} />

    <!-- Hreflang for bilingual SEO (omit on 404 — no paired ES/EN route) -->
    {!is404Page && (
      <>
        <link rel="alternate" hreflang="en-US" href={enUrl} />
        <link rel="alternate" hreflang="es-US" href={esUrl} />
        <link rel="alternate" hreflang="x-default" href={enUrl} />
      </>
    )}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content={locale === 'es' ? 'es_US' : 'en_US'} />
    {!is404Page && (
      <meta property="og:locale:alternate" content={locale === 'es' ? 'en_US' : 'es_US'} />
    )}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={twitterImageAlt} />

    <!-- Geo / local SEO -->
    <meta name="geo.region" content="US-FL" />
    <meta name="geo.placename" content="Cooper City, Davie; mailing address Miami Beach" />

    <link rel="icon" type="image/svg+xml" href="/cybercon-mark.svg" />
    <link rel="icon" href="/cybercon-mark.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Critical self-hosted fonts (latin body + display). -->
    <link rel="preload" href={interLatin400} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={soraLatin700} as="font" type="font/woff2" crossorigin />

    {structuredData.map((data) => (
      <script type="application/ld+json" set:html={jsonLdScript(data)} />
    ))}

    <Analytics />
    <slot name="head" />
    <script is:inline>
      // WebMCP (browser agent tools) — imperative registration when available
      (function () {
        function register() {
          var mc = navigator.modelContext;
          if (!mc || typeof mc.registerTool !== 'function') return;
          try {
            mc.registerTool({
              name: 'cybercon_site_info',
              description: 'Return Cybercon Solutions identity and agent discovery URLs.',
              inputSchema: { type: 'object', properties: {} },
              async execute() {
                return {
                  name: 'Cybercon Solutions',
                  url: 'https://cybercon-solutions.com',
                  llms: 'https://cybercon-solutions.com/llms.txt',
                  privacy: 'https://cybercon-solutions.com/privacy/',
                  apiCatalog: 'https://cybercon-solutions.com/.well-known/api-catalog',
                  auth: 'https://cybercon-solutions.com/auth.md',
                };
              },
            });
            mc.registerTool({
              name: 'cybercon_open_path',
              description: 'Navigate to a site-relative path such as /privacy/ or /es/.',
              inputSchema: {
                type: 'object',
                properties: { path: { type: 'string' } },
                required: ['path'],
              },
              async execute(args) {
                var path = (args && args.path) || '/';
                if (!path.startsWith('/')) path = '/' + path;
                window.location.assign(path);
                return { navigated: path };
              },
            });
            mc.registerTool({
              name: 'cybercon_list_services',
              description: 'List Cybercon Solutions service categories.',
              inputSchema: { type: 'object', properties: {} },
              async execute() {
                return {
                  services: [
                    'Managed IT Services',
                    'Cybersecurity & Compliance',
                    'Cloud Services & Architecture',
                    'IT Consulting & Strategic Leadership',
                    'Backup & Disaster Recovery',
                    'Structured Cabling & Communications',
                    'AI Consulting & Strategy',
                    'AI Integration & Automation',
                    'Conversational AI & Voice',
                    'Web Design & Development',
                  ],
                };
              },
            });
          } catch (e) {}
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', register);
        } else {
          register();
        }
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">
      {locale === 'es' ? 'Saltar al contenido' : 'Skip to content'}
    </a>

    <slot name="header" />

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <slot name="footer" />

    <CookieBanner
      locale={locale}
      title={t.cookies.title}
      body={t.cookies.body}
      acceptLabel={t.cookies.accept}
      declineLabel={t.cookies.decline}
      policyLabel={t.cookies.policy}
      policyHref={localePath(locale, '/privacy/')}
    />
  </body>
</html>
