---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import type { Service } from '../data/services';
import { getServiceDetails } from '../data/service-details';
import { buildServiceEditorial } from '../lib/service-editorial';
import { getMessages, localePath } from '../i18n';
import { faqPageJsonLd, jsonLdScript, serviceJsonLd } from '../lib/seo';

interface Props {
  locale: 'en' | 'es';
  service: Service;
}

const { locale, service } = Astro.props;
const t = getMessages(locale);
const details = getServiceDetails(service.slug);
if (!details) {
  throw new Error(`Missing service details for slug: ${service.slug}`);
}

const copy = buildServiceEditorial(service, details, locale, t);
const path = locale === 'es' ? `/es/services/${service.slug}/` : `/services/${service.slug}/`;
const homePath = localePath(locale, '/');
const assessmentHref = `${homePath}#assessment`;
const servicesHref = `${homePath}#services-title`;
const featureBodyParas = copy.feature.body.split(/\n\n+/).filter(Boolean);
---

<BaseLayout
  locale={locale}
  title={details.metaTitle[locale]}
  description={details.metaDescription[locale]}
  path={path}
  breadcrumbs={[
    { name: locale === 'es' ? 'Inicio' : 'Home', path: homePath },
    { name: service.title[locale], path },
  ]}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLdScript(serviceJsonLd(service, locale))} />
    <script type="application/ld+json" set:html={jsonLdScript(faqPageJsonLd(details.faqs, locale))} />
  </Fragment>

  <Header slot="header" locale={locale} t={t} variant="light" />

  <article class="wd" data-pagefind-body>
    <figure class="wd-banner">
      <picture>
        <source type="image/webp" srcset={copy.feature.image.webpSrcset} sizes="100vw" />
        <img
          src={copy.feature.image.jpg}
          srcset={copy.feature.image.jpgSrcset}
          sizes="100vw"
          alt={copy.feature.imageAlt}
          width={copy.feature.image.width}
          height={copy.feature.image.height}
          decoding="async"
          fetchpriority="high"
        />
      </picture>
    </figure>

    <section class="wd-hero container">
      <h1 class="wd-hero-title">{copy.displayTitle}</h1>
      <p class="wd-hero-lede">{copy.lede}</p>
      <div class="wd-hero-actions">
        <a class="btn btn-primary" href={assessmentHref}>{t.servicePage.cta}</a>
        <a class="wd-text-link" href={servicesHref}>{t.servicePage.back}</a>
      </div>
      <p class="wd-hero-note">{copy.replyNote}</p>
    </section>

    <hr class="wd-rule" />

    <section class="wd-split container" aria-labelledby="wd-audience-title">
      <div class="wd-split-lead">
        <p class="wd-label">{copy.audience.label}</p>
        <h2 id="wd-audience-title">{copy.audience.title}</h2>
      </div>
      <div class="wd-split-body">
        {copy.audience.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </section>

    <hr class="wd-rule" />

    <section class="wd-process container" aria-labelledby="wd-process-title">
      <h2 id="wd-process-title" class="wd-label">{copy.process.label}</h2>
      <ol class="wd-steps">
        {copy.process.steps.map((step) => (
          <li class="wd-step">
            <div class="wd-step-index">
              <span class="wd-step-mark" aria-hidden="true"></span>
              <span class="wd-step-num">{step.number}</span>
            </div>
            <h3 class="wd-step-title">{step.title}</h3>
            <p class="wd-step-body">{step.body}</p>
          </li>
        ))}
      </ol>
    </section>

    <hr class="wd-rule" />

    <section class="wd-after container" aria-labelledby="wd-feature-title">
      <header class="wd-after-head">
        <p class="wd-label">{copy.feature.label}</p>
        <h2 id="wd-feature-title">{copy.feature.title}</h2>
      </header>
      <div class="wd-after-body">
        {featureBodyParas.map((paragraph) => <p>{paragraph}</p>)}
      </div>
      {copy.included.length > 0 && (
        <ul class="wd-included">
          {copy.included.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      )}
    </section>

    <section class="wd-faq container" aria-labelledby="wd-faq-title">
      <h2 id="wd-faq-title" class="wd-label">{copy.faqLabel}</h2>
      <dl class="wd-faq-list">
        {copy.faqs.map((faq) => (
          <div class="wd-faq-row">
            <dt>{faq.question}</dt>
            <dd>{faq.answer}</dd>
          </div>
        ))}
      </dl>
    </section>

    <section class="wd-cta" aria-labelledby="wd-cta-title">
      <div class="wd-cta-shell container">
        <div class="wd-cta-copy">
          <h2 id="wd-cta-title">{copy.cta.title}</h2>
          <p class="wd-cta-lede">{copy.cta.body}</p>
          <a class="wd-cta-btn" href={assessmentHref}>{copy.cta.button}</a>
        </div>
        <figure class="wd-cta-media" aria-hidden="true">
          <picture>
            <source
              type="image/webp"
              srcset="/images/service-cta-desk-768.webp 768w, /images/service-cta-desk-960.webp 960w, /images/service-cta-desk.webp 1280w"
              sizes="(max-width: 860px) 100vw, 48vw"
            />
            <img
              src="/images/service-cta-desk.jpg"
              srcset="/images/service-cta-desk-768.jpg 768w, /images/service-cta-desk-960.jpg 960w, /images/service-cta-desk.jpg 1280w"
              sizes="(max-width: 860px) 100vw, 48vw"
              alt=""
              width="1280"
              height="854"
              loading="lazy"
              decoding="async"
            />
          </picture>
        </figure>
      </div>
    </section>
  </article>

  <Footer slot="footer" locale={locale} t={t} />
</BaseLayout>

<style is:global>
  body:has(.wd) {
    background: #f3f3f3;
  }

  body:has(.wd) .site-header.light {
    background: #f3f3f3;
  }

  .wd-banner {
    margin: 0;
    width: 100%;
    max-height: min(42vw, 420px);
    overflow: hidden;
    background: var(--navy);
  }

  .wd-banner img {
    display: block;
    width: 100%;
    height: min(42vw, 420px);
    object-fit: cover;
    object-position: center 35%;
  }
</style>

<style>
  .wd {
    background: #f3f3f3;
    color: var(--navy);
  }

  .wd :global(h1),
  .wd :global(h2),
  .wd :global(h3) {
    font-family: var(--font-heading);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--navy);
  }

  .wd-label,
  .wd :global(h2.wd-label) {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--button-red);
    margin: 0 0 1rem;
  }

  .wd-rule {
    border: 0;
    border-top: 1px solid rgba(15, 44, 76, 0.14);
    margin: 0;
  }

  .wd-hero {
    padding-block: clamp(2.75rem, 6vw, 4.5rem) clamp(2.5rem, 5vw, 3.75rem);
  }

  .wd-hero-title {
    font-size: clamp(2.35rem, 6vw, 3.75rem);
    line-height: 1.05;
    max-width: 16ch;
    margin: 0 0 1.25rem;
  }

  .wd-hero-lede {
    max-width: 42rem;
    font-size: clamp(1.05rem, 1.6vw, 1.2rem);
    line-height: 1.55;
    color: var(--navy);
    margin: 0 0 1.75rem;
  }

  .wd-hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.15rem 1.5rem;
    margin-bottom: 1rem;
  }

  .wd-text-link {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.9375rem;
    color: var(--button-red);
    text-decoration: none;
  }

  .wd-text-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .wd-hero-note {
    margin: 0;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--body-muted);
  }

  .wd-split {
    display: grid;
    gap: 1.75rem 3rem;
    padding-block: clamp(2.5rem, 5vw, 3.75rem);
  }

  .wd-split-lead h2 {
    font-size: clamp(1.55rem, 3vw, 2.05rem);
    line-height: 1.2;
    margin: 0;
    max-width: 22ch;
  }

  .wd-split-body {
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .wd-split-body p {
    margin: 0;
    color: var(--navy);
    font-size: 1.015rem;
    line-height: 1.6;
  }

  @media (min-width: 860px) {
    .wd-split {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
      align-items: start;
    }
  }

  .wd-process {
    padding-block: clamp(2.5rem, 5vw, 3.75rem);
  }

  .wd-steps {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .wd-step {
    display: grid;
    gap: 0.65rem 1.5rem;
    padding-block: 1.5rem;
    border-top: 1px solid rgba(15, 44, 76, 0.14);
  }

  .wd-step:last-child {
    border-bottom: 1px solid rgba(15, 44, 76, 0.14);
  }

  .wd-step-index {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }

  .wd-step-mark {
    width: 0.55rem;
    height: 0.55rem;
    background: var(--button-red);
    flex-shrink: 0;
  }

  .wd-step-num {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.04em;
    color: var(--navy);
  }

  .wd-step-title {
    font-size: clamp(1.35rem, 2.5vw, 1.75rem);
    margin: 0;
    line-height: 1.15;
  }

  .wd-step-body {
    margin: 0;
    color: var(--body-muted);
    font-size: 1.015rem;
    line-height: 1.55;
    max-width: 36rem;
  }

  @media (min-width: 860px) {
    .wd-step {
      grid-template-columns: 3.75rem minmax(11rem, 0.75fr) minmax(14rem, 1.25fr);
      align-items: start;
      column-gap: clamp(1.5rem, 4vw, 3rem);
      padding-block: 1.85rem;
    }

    .wd-step-body {
      justify-self: end;
      text-align: left;
      max-width: 30rem;
    }
  }

  .wd-after {
    display: grid;
    gap: 1.25rem;
    padding-block: clamp(2.5rem, 5vw, 3.75rem);
  }

  .wd-after-head h2 {
    font-size: clamp(1.85rem, 3.6vw, 2.55rem);
    line-height: 1.15;
    margin: 0;
    max-width: none;
  }

  .wd-after-body {
    display: grid;
    gap: 1rem;
    max-width: 62rem;
  }

  .wd-after-body p {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--navy);
  }

  .wd-included {
    display: grid;
    gap: 0.75rem 2.5rem;
    margin: 0.5rem 0 0;
    padding: 1.25rem 0 0;
    border-top: 1px solid rgba(15, 44, 76, 0.14);
    list-style: none;
    color: var(--navy);
    font-size: 1.015rem;
    line-height: 1.55;
  }

  .wd-included li {
    position: relative;
    padding-left: 1.15rem;
  }

  .wd-included li::before {
    content: '';
    position: absolute;
    top: 0.55em;
    left: 0;
    width: 0.45rem;
    height: 0.45rem;
    background: var(--button-red);
  }

  @media (min-width: 720px) {
    .wd-included {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .wd-faq {
    padding-block: clamp(2.5rem, 5vw, 3.75rem) clamp(3rem, 6vw, 4.5rem);
  }

  .wd-faq-list {
    margin: 0;
  }

  .wd-faq-row {
    display: grid;
    gap: 0.65rem 2.5rem;
    padding-block: 1.35rem;
    border-top: 1px solid rgba(15, 44, 76, 0.18);
  }

  .wd-faq-row:last-child {
    border-bottom: 1px solid rgba(15, 44, 76, 0.18);
  }

  .wd-faq-row dt {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--navy);
    line-height: 1.35;
  }

  .wd-faq-row dd {
    margin: 0;
    color: var(--body-muted);
    font-size: 1.015rem;
    line-height: 1.55;
  }

  @media (min-width: 860px) {
    .wd-faq-row {
      grid-template-columns: minmax(12rem, 0.9fr) minmax(14rem, 1.1fr);
      align-items: start;
      padding-block: 1.55rem;
    }
  }

  .wd-cta {
    position: relative;
    overflow: hidden;
    color: var(--white);
    background:
      radial-gradient(ellipse 70% 90% at 0% 0%, rgba(242, 107, 94, 0.55) 0%, transparent 58%),
      radial-gradient(ellipse 50% 60% at 18% 35%, rgba(242, 107, 94, 0.18) 0%, transparent 55%),
      linear-gradient(90deg, #0a1a2e 0%, #0f2c4c 48%, #0b1f35 100%);
    isolation: isolate;
  }

  .wd-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.22;
    background-image:
      linear-gradient(rgba(148, 180, 220, 0.35) 1px, transparent 1px),
      linear-gradient(90deg, rgba(148, 180, 220, 0.35) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: linear-gradient(105deg, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0.25) 42%, transparent 68%);
  }

  .wd-cta-shell {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 1.75rem;
    align-items: center;
    padding-block: clamp(2.75rem, 6vw, 4.5rem);
  }

  .wd-cta-copy {
    display: grid;
    gap: 1rem;
    justify-items: start;
    max-width: 34rem;
  }

  .wd-cta-copy h2 {
    margin: 0;
    color: var(--white);
    font-size: clamp(1.85rem, 4vw, 2.65rem);
    line-height: 1.12;
    max-width: 16ch;
  }

  .wd-cta-lede {
    margin: 0;
    color: rgba(255, 255, 255, 0.86);
    font-size: 1.05rem;
    line-height: 1.5;
    max-width: 28ch;
  }

  .wd-cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.35rem;
    padding: 0.8rem 1.2rem;
    border: 0;
    border-radius: 4px;
    background: var(--white);
    color: var(--button-red);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: background 160ms ease, color 160ms ease, transform 160ms ease;
  }

  .wd-cta-btn:hover {
    background: #fff5f3;
    color: #d45548;
  }

  .wd-cta-btn:focus-visible {
    outline: 2px solid var(--white);
    outline-offset: 3px;
  }

  .wd-cta-media {
    margin: 0;
    position: relative;
    overflow: hidden;
    min-height: 14rem;
    border-radius: 0;
  }

  .wd-cta-media img {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 14rem;
    object-fit: cover;
    object-position: center 40%;
  }

  .wd-cta-media::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      90deg,
      #0a1a2e 0%,
      rgba(10, 26, 46, 0.55) 28%,
      transparent 58%
    );
  }

  @media (min-width: 860px) {
    .wd-cta-shell {
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
      gap: clamp(1.5rem, 4vw, 3rem);
      min-height: 22rem;
    }

    .wd-cta-media {
      justify-self: stretch;
      align-self: stretch;
      min-height: 100%;
    }

    .wd-cta-media img {
      position: absolute;
      inset: 0;
      min-height: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .wd-cta-btn {
      transition: none;
    }
  }
</style>
