---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import type { Service } from '../data/services';
import { getServiceDetails } from '../data/service-details';
import { getMessages, localePath } from '../i18n';
import { faqPageJsonLd, jsonLdScript, serviceJsonLd } from '../lib/seo';

interface Props {
  locale: 'en' | 'es';
  service: Service;
}

const { locale, service } = Astro.props;
const t = getMessages(locale);
const details = getServiceDetails(service.slug);
if (!details) {
  throw new Error(`Missing service details for slug: ${service.slug}`);
}

const path = locale === 'es' ? `/es/services/${service.slug}/` : `/services/${service.slug}/`;
const homePath = localePath(locale, '/');
const title = details.metaTitle[locale];
const description = details.metaDescription[locale];
const assessmentHref = `${homePath}#assessment`;
const overviewParagraphs = details.overview[locale].split('\n\n').filter(Boolean);
---

<BaseLayout
  locale={locale}
  title={title}
  description={description}
  path={path}
  breadcrumbs={[
    { name: locale === 'es' ? 'Inicio' : 'Home', path: homePath },
    { name: service.title[locale], path },
  ]}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLdScript(serviceJsonLd(service, locale))} />
    <script type="application/ld+json" set:html={jsonLdScript(faqPageJsonLd(details.faqs, locale))} />
  </Fragment>

  <Header slot="header" locale={locale} t={t} variant="light" />

  <article class="service container" data-pagefind-body>
    <p class="eyebrow">{t.services.eyebrow}</p>
    <p class="num" aria-hidden="true">{service.id}</p>
    <h1>{service.title[locale]}</h1>
    <p class="lede">{service.summary[locale]}</p>

    <section class="block" aria-labelledby="audience-title">
      <h2 id="audience-title">{t.servicePage.audienceTitle}</h2>
      <p>{details.audience[locale]}</p>
    </section>

    <section class="block" aria-labelledby="overview-title">
      <h2 id="overview-title" class="visually-hidden">
        {locale === 'es' ? 'Descripción' : 'Overview'}
      </h2>
      {overviewParagraphs.map((paragraph) => (
        <p>{paragraph}</p>
      ))}
    </section>

    <section class="block" aria-labelledby="included-title">
      <h2 id="included-title">{t.servicePage.includedTitle}</h2>
      <ul>
        {service.items.map((item) => (
          <li>{item[locale]}</li>
        ))}
      </ul>
    </section>

    <section class="block" aria-labelledby="process-title">
      <h2 id="process-title">{t.servicePage.processTitle}</h2>
      <ol class="process">
        {details.process.map((step) => (
          <li>
            <h3>{step.title[locale]}</h3>
            <p>{step.body[locale]}</p>
          </li>
        ))}
      </ol>
    </section>

    <section class="block faq" aria-labelledby="faq-title">
      <h2 id="faq-title">{t.servicePage.faqTitle}</h2>
      {details.faqs.map((faq) => (
        <details>
          <summary>{faq.question[locale]}</summary>
          <p>{faq.answer[locale]}</p>
        </details>
      ))}
    </section>

    <section class="cta" aria-labelledby="service-cta-title">
      <h2 id="service-cta-title">{t.servicePage.ctaTitle}</h2>
      <p>{t.servicePage.ctaBody}</p>
      <a class="btn btn-primary" href={assessmentHref}>{t.servicePage.cta}</a>
    </section>

    <p class="back">
      <a href={`${homePath}#services-title`}>{t.servicePage.back}</a>
    </p>
  </article>

  <Footer slot="footer" locale={locale} t={t} />
</BaseLayout>

<style>
  .service {
    padding: clamp(2.5rem, 5vw, 4rem) 0 4rem;
    max-width: 44rem;
  }

  .num {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--coral);
    margin: 0.75rem 0 0.35rem;
  }

  .service h1 {
    font-size: clamp(1.85rem, 3.5vw, 2.5rem);
    color: var(--navy);
    margin-bottom: 0.85rem;
  }

  .lede {
    color: var(--body-muted);
    font-size: 1.0625rem;
    margin-bottom: 1.75rem;
  }

  .block {
    margin: 0 0 2rem;
  }

  .block h2 {
    font-size: 1.25rem;
    color: var(--navy);
    margin: 0 0 0.75rem;
  }

  .block p {
    color: var(--body-muted);
    margin: 0 0 0.85rem;
  }

  .block ul {
    margin: 0;
    padding-left: 1.15rem;
    color: var(--navy);
  }

  .block li + li {
    margin-top: 0.55rem;
  }

  .process {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 1rem;
  }

  .process h3 {
    font-size: 1rem;
    color: var(--navy);
    margin: 0 0 0.35rem;
  }

  .process p {
    margin: 0;
  }

  .faq details {
    border-top: 1px solid rgba(15, 44, 76, 0.12);
    padding: 0.85rem 0;
  }

  .faq details:last-of-type {
    border-bottom: 1px solid rgba(15, 44, 76, 0.12);
  }

  .faq summary {
    cursor: pointer;
    font-weight: 600;
    color: var(--navy);
  }

  .faq details p {
    margin: 0.65rem 0 0;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .cta {
    background: var(--cream);
    border: 1px solid rgba(15, 44, 76, 0.1);
    border-radius: var(--radius-md);
    padding: 1.35rem 1.4rem;
    display: grid;
    gap: 0.65rem;
    justify-items: start;
  }

  .cta h2 {
    font-size: 1.25rem;
    color: var(--navy);
  }

  .cta p {
    margin: 0;
    color: var(--body-muted);
  }

  .back {
    margin: 1.75rem 0 0;
  }

  .back a {
    color: var(--body-muted);
    font-size: 0.9375rem;
  }
</style>
