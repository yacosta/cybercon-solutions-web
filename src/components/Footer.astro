---
import { localePath, type Messages } from '../i18n';

interface Props {
  locale: string;
  t: Messages;
}

const { locale, t } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <p>{t.footer.area}</p>
    <p>
      © {year} CYBERCON SOLUTIONS.
      <a href={localePath(locale, '/privacy/')}>{t.footer.privacy}</a>
      ·
      <button type="button" class="cookie-reset" data-cookie-settings>
        {t.footer.cookies}
      </button>
    </p>
    <p class="contact">
      <a href="mailto:info@cybercon-solutions.com">info@cybercon-solutions.com</a>
      ·
      <a href="tel:+19735730007">973-573-0007</a>
    </p>
  </div>
</footer>

<script>
  document.querySelector('[data-cookie-settings]')?.addEventListener('click', () => {
    // Reopen banner without clearing choice until user accepts/declines again
    window.dispatchEvent(new CustomEvent('cybercon:cookie-settings'));
  });
</script>

<style>
  .site-footer {
    padding: 2rem 0 5rem;
    color: var(--body-muted);
    font-size: 0.8125rem;
  }

  .footer-inner {
    display: grid;
    gap: 0.35rem;
  }

  .site-footer a,
  .cookie-reset {
    color: var(--navy);
  }

  .cookie-reset {
    background: none;
    border: none;
    padding: 0;
    font: inherit;
    cursor: pointer;
    text-decoration: underline;
    min-height: 44px;
  }

  .cookie-reset:focus-visible {
    outline: 2px solid var(--coral);
    outline-offset: 2px;
  }

  .contact a {
    text-decoration: none;
  }

  .contact a:hover,
  .contact a:focus-visible {
    text-decoration: underline;
  }
</style>
