---
import { localePath, type Messages } from '../i18n';

interface Props {
  locale: string;
  t: Messages;
}

const { locale, t } = Astro.props;
const heartLabel = locale === 'es' ? 'con cariño' : 'with love';
---

<footer class="site-footer">
  <p>
    <span class="servicing">
      {t.footer.area}
      {' '}
      <span class="heart" role="img" aria-label={heartLabel}>&#10084;</span>
    </span>
    <span class="divider" aria-hidden="true">|</span>
    {t.footer.copyright}
    <span class="divider" aria-hidden="true">|</span>
    <a href={localePath(locale, '/privacy/')}>{t.footer.privacy}</a>
    <span class="divider" aria-hidden="true">|</span>
    <button type="button" class="cookie-reset" data-cookie-settings>
      {t.footer.cookies}
    </button>
  </p>
</footer>

<script>
  document.querySelector('[data-cookie-settings]')?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('cybercon:cookie-settings'));
  });
</script>

<style>
  .site-footer {
    background: var(--navy);
    padding: 28px clamp(1.5rem, 5vw, 4.5rem);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .site-footer p {
    margin: 0;
    font-size: 0.8125rem;
    letter-spacing: 0.02em;
    color: var(--muted-blue);
    text-align: center;
    line-height: 1.7;
  }

  .servicing {
    color: #c6d2de;
  }

  .heart {
    color: var(--coral);
  }

  .divider {
    color: rgba(140, 160, 180, 0.5);
    margin: 0 10px;
  }

  .site-footer a,
  .cookie-reset {
    color: var(--muted-blue);
    text-decoration: underline;
  }

  .cookie-reset {
    background: none;
    border: none;
    padding: 0;
    font: inherit;
    cursor: pointer;
    min-height: 44px;
  }

  .site-footer a:hover,
  .cookie-reset:hover {
    color: var(--cream);
  }

  .cookie-reset:focus-visible,
  .site-footer a:focus-visible {
    outline: 2px solid var(--coral);
    outline-offset: 2px;
  }

  @media (max-width: 720px) {
    .divider {
      display: none;
    }

    .site-footer p {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.45rem;
    }
  }
</style>
