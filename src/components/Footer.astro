---
import { localePath, type Messages } from '../i18n';
import { site } from '../lib/site';

interface Props {
  locale: string;
  t: Messages;
}

const { locale, t } = Astro.props;
const heartLabel = locale === 'es' ? 'con cariño' : 'with love';
---

<footer class="site-footer">
  <div class="footer-inner">
    <p class="footer-line">
      <span class="servicing">
        {t.footer.area}
        {' '}
        <span class="heart" role="img" aria-label={heartLabel}>&#10084;</span>
      </span>
      <span class="divider" aria-hidden="true">|</span>
      <span class="mailing">{t.footer.mailing}</span>
      <span class="divider" aria-hidden="true">|</span>
      {t.footer.copyright}
      <span class="divider" aria-hidden="true">|</span>
      <a href={localePath(locale, '/privacy/')}>{t.footer.privacy}</a>
      <span class="divider" aria-hidden="true">|</span>
      <button type="button" class="cookie-reset" data-cookie-settings>
        {t.footer.cookies}
      </button>
    </p>
    <p class="footer-contact">
      <a href={`mailto:${site.email}`}>{site.email}</a>
      <span class="divider" aria-hidden="true">|</span>
      <a href={`tel:${site.phone}`}>{site.phoneDisplay}</a>
    </p>
  </div>
</footer>

<script>
  document.querySelector('[data-cookie-settings]')?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('cybercon:cookie-settings'));
  });
</script>

<style>
  .site-footer {
    background: var(--navy);
    padding: 28px clamp(1.5rem, 5vw, 4.5rem);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer-inner {
    display: grid;
    gap: 0.55rem;
    justify-items: center;
    text-align: center;
  }

  .footer-line,
  .footer-contact {
    margin: 0;
    font-size: 0.8125rem;
    letter-spacing: 0.02em;
    color: var(--muted-blue);
    line-height: 1.7;
  }

  .servicing {
    color: #c6d2de;
  }

  .heart {
    color: var(--coral);
    display: inline-block;
    transform-origin: center;
    animation: heart-pulse 1.5s alternate infinite ease-in;
  }

  @keyframes heart-pulse {
    0% {
      transform: scale(0.75);
    }

    100% {
      transform: scale(1.1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .heart {
      animation: none;
    }
  }

  .divider {
    color: rgba(140, 160, 180, 0.5);
    margin: 0 10px;
  }

  .site-footer a,
  .cookie-reset {
    color: var(--muted-blue);
    text-decoration: underline;
  }

  .cookie-reset {
    background: none;
    border: none;
    padding: 0;
    font: inherit;
    cursor: pointer;
    min-height: 44px;
  }

  .site-footer a:hover,
  .cookie-reset:hover {
    color: var(--cream);
  }

  .cookie-reset:focus-visible,
  .site-footer a:focus-visible {
    outline: 2px solid var(--coral);
    outline-offset: 2px;
  }

  @media (max-width: 720px) {
    .divider {
      display: none;
    }

    .footer-line,
    .footer-contact {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.45rem;
    }
  }
</style>
