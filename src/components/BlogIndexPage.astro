---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { getMessages, localePath } from '../i18n';
import {
  bannerImage,
  blogPath,
  formatPostDate,
  getPublishedPosts,
  postDescription,
  postTitle,
} from '../lib/blog';

interface Props {
  locale: 'en' | 'es';
}

const { locale } = Astro.props;
const t = getMessages(locale);
const posts = await getPublishedPosts();
const path = blogPath(locale);
const homePath = localePath(locale, '/');
---

<BaseLayout
  locale={locale}
  title={t.blog.indexTitle}
  description={t.blog.indexDescription}
  path={path}
  breadcrumbs={[
    { name: locale === 'es' ? 'Inicio' : 'Home', path: homePath },
    { name: t.blog.nav, path },
  ]}
>
  <Header slot="header" locale={locale} t={t} variant="light" />

  <section class="blog-index container page" data-pagefind-body>
    <header class="blog-index-head">
      <p class="eyebrow">{t.blog.eyebrow}</p>
      <h1>{t.blog.indexHeading}</h1>
      <p class="lede">{t.blog.indexLede}</p>
    </header>

    <ul class="blog-list">
      {posts.map((post) => {
        const title = postTitle(post, locale);
        const description = postDescription(post, locale);
        const href = blogPath(locale, post.id);
        const banner = bannerImage(post.data.banner);
        const date = formatPostDate(post.data.pubDate, locale);
        return (
          <li>
            <a class="blog-row" href={href}>
              <div class="blog-row-media" aria-hidden="true">
                <picture>
                  <source
                    type="image/webp"
                    srcset={banner.webpSrcset}
                    sizes="(max-width: 720px) 100vw, 220px"
                  />
                  <img
                    src={banner.jpg}
                    srcset={banner.jpgSrcset}
                    sizes="(max-width: 720px) 100vw, 220px"
                    alt=""
                    width={banner.width}
                    height={banner.height}
                    loading="lazy"
                    decoding="async"
                  />
                </picture>
              </div>
              <div class="blog-row-copy">
                <time datetime={post.data.pubDate.toISOString()}>{date}</time>
                <h2>{title}</h2>
                <p>{description}</p>
                <span class="blog-row-more">{t.blog.readMore}</span>
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  </section>

  <Footer slot="footer" locale={locale} t={t} />
</BaseLayout>

<style>
  .blog-index {
    color: var(--body-muted);
  }

  .blog-index-head {
    margin-bottom: 2.25rem;
    max-width: 40rem;
  }

  .blog-index-head h1 {
    margin: 0.35rem 0 0.75rem;
    font-size: clamp(1.85rem, 3.2vw, 2.4rem);
    color: var(--navy);
    letter-spacing: -0.03em;
  }

  .lede {
    margin: 0;
    font-size: 1.05rem;
    color: var(--navy);
  }

  .blog-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .blog-list > li + li {
    border-top: 1px solid rgba(15, 44, 76, 0.1);
  }

  .blog-row {
    display: grid;
    grid-template-columns: minmax(0, 220px) minmax(0, 1fr);
    gap: 1.35rem;
    align-items: start;
    text-decoration: none;
    color: inherit;
    padding: 1.35rem 0;
  }

  .blog-row:hover h2,
  .blog-row:hover .blog-row-more {
    color: var(--coral);
  }

  .blog-row-media {
    margin: 0;
    overflow: hidden;
    background: var(--navy);
    aspect-ratio: 16 / 10;
  }

  .blog-row-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
  }

  .blog-row-copy {
    display: grid;
    gap: 0.45rem;
    padding-top: 0.15rem;
  }

  .blog-row-copy time {
    font-size: 0.8125rem;
    color: var(--muted-blue);
  }

  .blog-row-copy h2 {
    margin: 0;
    font-size: clamp(1.15rem, 2vw, 1.35rem);
    line-height: 1.3;
    color: var(--navy);
    transition: color 0.15s;
  }

  .blog-row-copy p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.55;
    max-width: 42rem;
  }

  .blog-row-more {
    margin-top: 0.2rem;
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--navy);
    transition: color 0.15s;
  }

  @media (max-width: 720px) {
    .blog-row {
      grid-template-columns: 1fr;
      gap: 0.85rem;
    }
  }
</style>
