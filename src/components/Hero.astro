---
import type { Messages } from '../i18n';

interface Props {
  locale: 'en' | 'es';
  t: Messages;
  posterSrc?: string;
  videoSrc?: string;
}

const {
  locale,
  t,
  posterSrc = '/videos/hero-poster.jpg',
  videoSrc = '/videos/hero-server-racks.webm',
} = Astro.props;

const videoLabel =
  locale === 'es'
    ? 'Vídeo decorativo: ingeniero de redes trabajando entre racks de servidores'
    : 'Decorative video: network engineer walking through server racks and working on a server';
---

<section
  class="hero"
  aria-labelledby="hero-title"
  aria-describedby="hero-lede"
>
  <div class="hero-media" aria-hidden="true">
    <img
      class="hero-poster"
      src={posterSrc}
      alt=""
      width="1920"
      height="1080"
      fetchpriority="high"
      decoding="async"
    />
    <video
      class="hero-video"
      muted
      loop
      playsinline
      preload="none"
      poster={posterSrc}
      tabindex="-1"
    >
      <source data-src={videoSrc} type="video/webm" />
    </video>
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-content">
    <p class="eyebrow">{t.hero.eyebrow}</p>
    <h1 id="hero-title">{t.hero.title}</h1>
    <p id="hero-lede" class="lede">{t.hero.lede}</p>
    <p class="status">
      <span class="status-dot" aria-hidden="true"></span>
      {t.hero.status}
    </p>
    <p class="sr-only">{videoLabel}</p>
  </div>
</section>

<script>
  function loadHeroVideo() {
    const video = document.querySelector('.hero-video');
    if (!(video instanceof HTMLVideoElement)) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      video.remove();
      return;
    }
    const source = video.querySelector('source[data-src]');
    if (source instanceof HTMLSourceElement && source.dataset.src) {
      source.src = source.dataset.src;
      source.removeAttribute('data-src');
      video.load();
      video.play().catch(() => {
        /* Autoplay blocked — poster remains visible */
      });
    }
  }

  if (document.readyState === 'complete') {
    setTimeout(loadHeroVideo, 200);
  } else {
    window.addEventListener('load', () => setTimeout(loadHeroVideo, 200), { once: true });
  }
</script>

<style>
  .hero {
    position: relative;
    min-height: min(88vh, 760px);
    display: grid;
    align-items: end;
    color: var(--white);
    overflow: hidden;
    isolation: isolate;
  }

  .hero-media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-poster,
  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(105deg, rgba(15, 44, 76, 0.92) 0%, rgba(15, 44, 76, 0.72) 48%, rgba(15, 44, 76, 0.45) 100%),
      linear-gradient(to top, rgba(15, 44, 76, 0.85) 0%, transparent 45%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    width: min(1120px, calc(100% - 2.5rem));
    margin: 0 auto;
    padding: clamp(5rem, 12vw, 7rem) 0 clamp(2.5rem, 6vw, 4rem);
    max-width: 38rem;
    justify-self: start;
    margin-left: max(1.25rem, calc((100% - 1120px) / 2 + 1.25rem));
  }

  .hero h1 {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    line-height: 1.06;
    letter-spacing: -0.02em;
    margin: 0.75rem 0 1rem;
    color: var(--white);
    text-shadow: 0 1px 18px rgba(0, 0, 0, 0.35);
  }

  .lede {
    color: var(--secondary-dark);
    font-size: clamp(1rem, 1.4vw, 1.125rem);
    line-height: 1.65;
    margin-bottom: 1.25rem;
  }

  .status {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    color: var(--secondary-dark);
    font-size: 0.9375rem;
    margin: 0;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--coral);
    flex-shrink: 0;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-video {
      display: none !important;
    }
  }
</style>
