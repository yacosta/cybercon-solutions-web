---
import Wordmark from './Wordmark.astro';
import { localePath, type Messages } from '../i18n';

interface Props {
  locale: string;
  t: Messages;
  variant?: 'dark' | 'light';
}

const { locale, t, variant = 'dark' } = Astro.props;
const homeHref = localePath(locale, '/');
const searchHref = localePath(locale, '/search/');
const privacyHref = localePath(locale, '/privacy/');
const enHref = locale === 'es' ? Astro.url.pathname.replace(/^\/es/, '') || '/' : Astro.url.pathname;
const esHref = locale === 'es' ? Astro.url.pathname : Astro.url.pathname === '/' ? '/es/' : `/es${Astro.url.pathname}`;
---

<header class="site-header">
  <Wordmark variant={variant} href={homeHref} />
  <nav class="site-nav" aria-label={locale === 'es' ? 'Principal' : 'Primary'}>
    <a href={searchHref}>{t.nav.search}</a>
    <a href="/client/">{t.nav.client}</a>
    <a href={privacyHref} class="nav-privacy">{t.nav.privacy}</a>
    <div class="lang" role="group" aria-label={locale === 'es' ? 'Idioma' : 'Language'}>
      <a
        href={enHref}
        lang="en"
        hreflang="en"
        aria-current={locale === 'en' ? 'page' : undefined}
        class:list={[{ active: locale === 'en' }]}
      >
        EN
      </a>
      <span aria-hidden="true">/</span>
      <a
        href={esHref}
        lang="es"
        hreflang="es"
        aria-current={locale === 'es' ? 'page' : undefined}
        class:list={[{ active: locale === 'es' }]}
      >
        ES
      </a>
    </div>
  </nav>
</header>

<style>
  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem clamp(1.25rem, 3vw, 2rem);
    position: relative;
    z-index: 2;
  }

  .site-header:has(.wordmark.light) {
    background: var(--cream);
    border-bottom: 1px solid rgba(15, 44, 76, 0.08);
  }

  .site-nav {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.85rem 1rem;
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.06em;
  }

  .site-nav a {
    text-decoration: none;
    color: var(--secondary-dark);
    transition: color 0.15s;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0;
  }

  .site-header:has(.wordmark.light) .site-nav a {
    color: var(--body-muted);
  }

  .site-nav a:hover,
  .site-nav a:focus-visible {
    color: var(--white);
  }

  .site-header:has(.wordmark.light) .site-nav a:hover,
  .site-header:has(.wordmark.light) .site-nav a:focus-visible {
    color: var(--navy);
  }

  .site-nav a:focus-visible {
    outline: 2px solid var(--coral);
    outline-offset: 3px;
    border-radius: 4px;
  }

  .nav-privacy {
    display: none;
  }

  @media (min-width: 720px) {
    .nav-privacy {
      display: inline-flex;
    }
  }

  .lang {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }

  .lang span {
    color: rgba(140, 160, 180, 0.5);
  }

  .lang a.active {
    color: var(--coral);
  }
</style>
