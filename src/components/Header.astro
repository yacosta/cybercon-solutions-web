---
import Wordmark from './Wordmark.astro';
import { localePath, type Messages } from '../i18n';
import { services, servicePath } from '../data/services';

interface Props {
  locale: string;
  t: Messages;
  variant?: 'dark' | 'light';
}

const { locale, t, variant = 'dark' } = Astro.props;
const homeHref = localePath(locale, '/');
const searchHref = localePath(locale, '/search/');
const blogHref = localePath(locale, '/blog/');
const assessmentHref = `${homeHref}#assessment`;
const path = Astro.url.pathname;
const onHome = path === '/' || path === '/es' || path === '/es/';
const onBlog = path === '/blog' || path.startsWith('/blog/') || path === '/es/blog' || path.startsWith('/es/blog/');
const onServices = path.includes('/services/');
const enHref = locale === 'es' ? path.replace(/^\/es/, '') || '/' : path;
const esHref = locale === 'es' ? path : path === '/' ? '/es/' : `/es${path}`;
const serviceLinks = services.map((service) => ({
  href: servicePath(locale, service.slug),
  title: service.title[locale as 'en' | 'es'],
  current: path.includes(`/services/${service.slug}`),
}));
---

<header class:list={['site-header', variant]} data-site-header>
  <div class="header-inner">
    <Wordmark variant={variant} href={homeHref} />

    <div class="header-right">
      <nav class="site-nav" data-desktop-nav aria-label={locale === 'es' ? 'Principal' : 'Primary'}>
        <a
          href={homeHref}
          class:list={['nav-link', { active: onHome }]}
          aria-current={onHome ? 'page' : undefined}
        >
          <span class="nav-dot" aria-hidden="true"></span>
          <span>{t.nav.home}</span>
        </a>

        <div class="nav-dropdown" data-nav-dropdown>
          <button
            type="button"
            class:list={['nav-link', 'nav-dropdown-toggle', { active: onServices }]}
            data-nav-dropdown-toggle
            aria-expanded="false"
            aria-controls="nav-services-menu"
            aria-haspopup="true"
          >
            <span class="nav-dot" aria-hidden="true"></span>
            <span>{t.nav.services}</span>
          </button>
          <ul
            id="nav-services-menu"
            class="nav-dropdown-menu"
            data-nav-dropdown-menu
            aria-label={t.nav.servicesMenu}
            hidden
          >
            {
              serviceLinks.map((service) => (
                <li>
                  <a
                    href={service.href}
                    class:list={[{ active: service.current }]}
                    aria-current={service.current ? 'page' : undefined}
                  >
                    {service.title}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <a
          href={blogHref}
          class:list={['nav-link', { active: onBlog }]}
          aria-current={onBlog ? 'page' : undefined}
        >
          <span class="nav-dot" aria-hidden="true"></span>
          <span>{t.blog.nav}</span>
        </a>
      </nav>

      <div class="header-tools">
        <div class="header-search" data-header-search>
          <div class="search-pill" data-search-pill>
            <button
              type="button"
              class="search-toggle"
              data-search-toggle
              aria-label={t.nav.searchOpen}
              aria-expanded="false"
              aria-controls="site-search-input"
            >
              <svg width="17" height="17" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                <circle cx="7.5" cy="7.5" r="5.5" stroke="currentColor" stroke-width="1.3"></circle>
                <line
                  x1="11.6"
                  y1="11.6"
                  x2="16"
                  y2="16"
                  stroke="currentColor"
                  stroke-width="1.3"
                  stroke-linecap="round"></line>
              </svg>
            </button>
            <input
              id="site-search-input"
              class="search-input"
              data-search-input
              type="search"
              enterkeyhint="search"
              autocomplete="off"
              placeholder={t.nav.searchPlaceholder}
              aria-label={t.nav.searchLabel}
              aria-controls="site-search-results"
            />
          </div>

          <div
            id="site-search-results"
            class="search-results"
            data-search-results
            role="listbox"
            aria-label={t.nav.searchResults}
            hidden
          ></div>
        </div>

        <div class="lang" role="group" aria-label={locale === 'es' ? 'Idioma' : 'Language'}>
          <a
            href={enHref}
            lang="en"
            hreflang="en"
            aria-current={locale === 'en' ? 'page' : undefined}
            class:list={[{ active: locale === 'en' }]}
          >
            EN
          </a>
          <span aria-hidden="true">/</span>
          <a
            href={esHref}
            lang="es"
            hreflang="es"
            aria-current={locale === 'es' ? 'page' : undefined}
            class:list={[{ active: locale === 'es' }]}
          >
            ES
          </a>
        </div>

        <a class="nav-cta" href={assessmentHref}>{t.hero.cta}</a>

        <button
          type="button"
          class="menu-dot"
          data-menu-toggle
          aria-expanded="false"
          aria-controls="site-menu-panel"
          aria-label={t.nav.menu}
        >
          <span class="menu-dot-core" aria-hidden="true"></span>
        </button>
      </div>
    </div>
  </div>

  <div class="menu-panel" id="site-menu-panel" data-menu-panel aria-hidden="true">
    <nav class="menu-panel-nav" aria-label={locale === 'es' ? 'Principal' : 'Primary'}>
      <a
        href={homeHref}
        class:list={['menu-panel-link', { active: onHome }]}
        aria-current={onHome ? 'page' : undefined}
      >
        <span class="nav-dot" aria-hidden="true"></span>
        <span>{t.nav.home}</span>
      </a>
      <p class="menu-panel-label">{t.nav.services}</p>
      {
        serviceLinks.map((service) => (
          <a
            href={service.href}
            class:list={['menu-panel-link', 'is-service', { active: service.current }]}
            aria-current={service.current ? 'page' : undefined}
          >
            <span class="nav-dot" aria-hidden="true"></span>
            <span>{service.title}</span>
          </a>
        ))
      }
      <a
        href={blogHref}
        class:list={['menu-panel-link', { active: onBlog }]}
        aria-current={onBlog ? 'page' : undefined}
      >
        <span class="nav-dot" aria-hidden="true"></span>
        <span>{t.blog.nav}</span>
      </a>
      <div class="menu-panel-lang" role="group" aria-label={locale === 'es' ? 'Idioma' : 'Language'}>
        <a
          href={enHref}
          lang="en"
          hreflang="en"
          aria-current={locale === 'en' ? 'page' : undefined}
          class:list={[{ active: locale === 'en' }]}
        >
          EN
        </a>
        <span aria-hidden="true">/</span>
        <a
          href={esHref}
          lang="es"
          hreflang="es"
          aria-current={locale === 'es' ? 'page' : undefined}
          class:list={[{ active: locale === 'es' }]}
        >
          ES
        </a>
      </div>
      <a class="menu-panel-cta" href={assessmentHref}>{t.hero.cta}</a>
    </nav>
  </div>
</header>

<script define:vars={{
  searchHref,
  labels: {
    open: t.nav.searchOpen,
    close: t.nav.searchClose,
    empty: t.nav.searchEmpty,
    unavailable: t.nav.searchUnavailable,
    allResults: t.nav.searchAllResults,
    menu: t.nav.menu,
    menuClose: t.nav.close,
  },
}}>
  const root = document.querySelector('[data-header-search]');
  const pill = root?.querySelector('[data-search-pill]');
  const toggle = root?.querySelector('[data-search-toggle]');
  const input = root?.querySelector('[data-search-input]');
  const resultsEl = root?.querySelector('[data-search-results]');

  if (
    root instanceof HTMLElement &&
    pill instanceof HTMLElement &&
    toggle instanceof HTMLButtonElement &&
    input instanceof HTMLInputElement &&
    resultsEl instanceof HTMLElement
  ) {
    let open = false;
    let pagefindPromise = null;
    let requestId = 0;
    let debounceTimer = 0;

    const setOpen = (next) => {
      open = next;
      root.classList.toggle('is-open', next);
      toggle.setAttribute('aria-expanded', String(next));
      toggle.setAttribute('aria-label', next ? labels.close : labels.open);
      if (!next) {
        resultsEl.hidden = true;
        resultsEl.innerHTML = '';
      } else {
        input.focus();
      }
    };

    const loadPagefind = () => {
      if (!pagefindPromise) {
        pagefindPromise = import('/pagefind/pagefind.js')
          .then((mod) => mod)
          .catch(() => null);
      }
      return pagefindPromise;
    };

    const renderResults = (term, items, unavailable = false) => {
      if (!term) {
        resultsEl.hidden = true;
        resultsEl.innerHTML = '';
        return;
      }
      if (unavailable) {
        resultsEl.innerHTML = `<p class="search-empty">${labels.unavailable}</p>`;
        resultsEl.hidden = false;
        return;
      }
      if (!items.length) {
        resultsEl.innerHTML = `<p class="search-empty">${labels.empty.replace('{query}', term)}</p>`;
        resultsEl.hidden = false;
        return;
      }

      const links = items
        .map(
          (item) =>
            `<a href="${item.href}" role="option" class="search-result">${item.title}</a>`,
        )
        .join('');
      const more = `<a href="${searchHref}?q=${encodeURIComponent(term)}" class="search-more">${labels.allResults}</a>`;
      resultsEl.innerHTML = `${links}${more}`;
      resultsEl.hidden = false;
    };

    const runSearch = async (query) => {
      const term = query.trim();
      const id = ++requestId;
      if (!term) {
        renderResults('', []);
        return;
      }

      try {
        const pagefind = await loadPagefind();
        if (!pagefind) {
          if (id !== requestId) return;
          renderResults(term, [], true);
          return;
        }
        const search = await pagefind.search(term);
        const data = await Promise.all(search.results.slice(0, 6).map((result) => result.data()));
        if (id !== requestId) return;
        renderResults(
          term,
          data.map((item) => ({
            title: item.meta?.title || item.url,
            href: item.url,
          })),
        );
      } catch {
        if (id !== requestId) return;
        renderResults(term, [], true);
      }
    };

    toggle.addEventListener('click', () => setOpen(!open));

    input.addEventListener('input', () => {
      window.clearTimeout(debounceTimer);
      debounceTimer = window.setTimeout(() => runSearch(input.value), 160);
    });

    input.addEventListener('keydown', (event) => {
      if (event.key === 'Enter') {
        event.preventDefault();
        const term = input.value.trim();
        if (term) window.location.assign(`${searchHref}?q=${encodeURIComponent(term)}`);
      }
      if (event.key === 'Escape') setOpen(false);
    });

    document.addEventListener('pointerdown', (event) => {
      if (!open) return;
      const target = event.target;
      if (target instanceof Node && !root.contains(target)) setOpen(false);
    });
  }

  const header = document.querySelector('[data-site-header]');
  const menuToggle = header?.querySelector('[data-menu-toggle]');
  const menuPanel = header?.querySelector('[data-menu-panel]');
  const dropdown = header?.querySelector('[data-nav-dropdown]');
  const dropdownToggle = dropdown?.querySelector('[data-nav-dropdown-toggle]');
  const dropdownMenu = dropdown?.querySelector('[data-nav-dropdown-menu]');

  if (
    header instanceof HTMLElement &&
    menuToggle instanceof HTMLButtonElement &&
    menuPanel instanceof HTMLElement
  ) {
    const setMenuOpen = (next) => {
      header.classList.toggle('is-menu-open', next);
      menuPanel.classList.toggle('is-open', next);
      menuToggle.setAttribute('aria-expanded', String(next));
      menuToggle.setAttribute('aria-label', next ? labels.menuClose : labels.menu);
      menuPanel.setAttribute('aria-hidden', String(!next));
      document.documentElement.classList.toggle('menu-open', next);
    };

    menuToggle.addEventListener('click', () => {
      setMenuOpen(!header.classList.contains('is-menu-open'));
    });

    menuPanel.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => setMenuOpen(false));
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && header.classList.contains('is-menu-open')) {
        setMenuOpen(false);
        menuToggle.focus();
      }
    });

    document.addEventListener('pointerdown', (event) => {
      if (!header.classList.contains('is-menu-open')) return;
      const target = event.target;
      if (target instanceof Node && !header.contains(target)) setMenuOpen(false);
    });
  }

  if (
    dropdown instanceof HTMLElement &&
    dropdownToggle instanceof HTMLButtonElement &&
    dropdownMenu instanceof HTMLElement
  ) {
    const setDropdownOpen = (next) => {
      dropdown.classList.toggle('is-open', next);
      dropdownToggle.setAttribute('aria-expanded', String(next));
      dropdownMenu.hidden = !next;
    };

    dropdownToggle.addEventListener('click', () => {
      setDropdownOpen(dropdownMenu.hidden);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && !dropdownMenu.hidden) {
        setDropdownOpen(false);
        dropdownToggle.focus();
      }
    });

    document.addEventListener('pointerdown', (event) => {
      if (dropdownMenu.hidden) return;
      const target = event.target;
      if (target instanceof Node && !dropdown.contains(target)) setDropdownOpen(false);
    });
  }
</script>

<style is:global>
  html.menu-open {
    overflow: hidden;
  }
</style>

<style>
  .site-header {
    position: relative;
    z-index: 40;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .site-header.dark {
    background: rgba(15, 44, 76, 0.28);
    border-bottom: 0.5px solid rgba(255, 255, 255, 0.2);
  }

  .site-header.light {
    background: rgba(247, 244, 241, 0.88);
    border-bottom: 0.5px solid rgba(15, 44, 76, 0.2);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 4rem;
    padding: 0 var(--page-inline);
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    min-width: 0;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 0.05rem;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 400;
    letter-spacing: 0;
  }

  .nav-link,
  .nav-dropdown-toggle {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    min-height: 44px;
    padding: 0.35rem 0.7rem;
    border: none;
    background: none;
    color: var(--secondary-dark);
    font: inherit;
    text-decoration: none;
    cursor: pointer;
    transition: color 0.15s;
  }

  .site-header.light .nav-link,
  .site-header.light .nav-dropdown-toggle {
    color: var(--body-muted);
  }

  .nav-link:hover,
  .nav-link:focus-visible,
  .nav-dropdown-toggle:hover,
  .nav-dropdown-toggle:focus-visible {
    color: var(--white);
  }

  .site-header.light .nav-link:hover,
  .site-header.light .nav-link:focus-visible,
  .site-header.light .nav-dropdown-toggle:hover,
  .site-header.light .nav-dropdown-toggle:focus-visible {
    color: var(--navy);
  }

  .nav-link:focus-visible,
  .nav-dropdown-toggle:focus-visible,
  .menu-dot:focus-visible,
  .nav-cta:focus-visible {
    outline: 2px solid var(--coral);
    outline-offset: 3px;
    border-radius: 4px;
  }

  .nav-dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--coral);
    opacity: 0;
    transform: scale(0.6);
    transition:
      opacity 0.15s,
      transform 0.15s;
    flex-shrink: 0;
  }

  .nav-link.active .nav-dot,
  .nav-dropdown-toggle.active .nav-dot,
  .menu-panel-link.active .nav-dot {
    opacity: 1;
    transform: scale(1);
  }

  .nav-link.active,
  .nav-dropdown-toggle.active {
    color: var(--white);
  }

  .site-header.light .nav-link.active,
  .site-header.light .nav-dropdown-toggle.active {
    color: var(--navy);
  }

  .nav-dropdown {
    position: relative;
  }

  @media (hover: hover) and (pointer: fine) {
    .nav-dropdown:hover .nav-dropdown-menu,
    .nav-dropdown:focus-within .nav-dropdown-menu {
      display: block;
    }

    .nav-dropdown:hover .nav-dropdown-menu[hidden],
    .nav-dropdown:focus-within .nav-dropdown-menu[hidden] {
      display: block;
    }
  }

  .nav-dropdown-menu {
    position: absolute;
    top: calc(100% + 0.35rem);
    left: 0;
    z-index: 50;
    margin: 0;
    padding: 0.4rem;
    list-style: none;
    min-width: min(18rem, 88vw);
    max-height: min(70vh, 28rem);
    overflow-y: auto;
    background: rgba(15, 44, 76, 0.96);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.28);
  }

  .site-header.light .nav-dropdown-menu {
    background: rgba(255, 255, 255, 0.98);
    border-color: rgba(15, 44, 76, 0.1);
    box-shadow: 0 16px 36px rgba(15, 44, 76, 0.12);
  }

  .nav-dropdown-menu a {
    display: flex;
    align-items: center;
    min-height: 42px;
    padding: 0.5rem 0.7rem;
    border-radius: 6px;
    color: var(--secondary-dark);
    text-decoration: none;
    font-size: 0.8125rem;
    line-height: 1.35;
  }

  .site-header.light .nav-dropdown-menu a {
    color: var(--navy);
  }

  .nav-dropdown-menu a:hover,
  .nav-dropdown-menu a:focus-visible,
  .nav-dropdown-menu a.active {
    background: rgba(255, 255, 255, 0.08);
    color: var(--white);
  }

  .site-header.light .nav-dropdown-menu a:hover,
  .site-header.light .nav-dropdown-menu a:focus-visible {
    background: rgba(15, 44, 76, 0.05);
    color: var(--navy);
  }

  .site-header.light .nav-dropdown-menu a.active,
  .nav-dropdown-menu a.active {
    color: var(--coral);
  }

  .header-tools {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  .lang {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
  }

  .lang span {
    color: rgba(140, 160, 180, 0.5);
  }

  .lang a {
    color: var(--secondary-dark);
    text-decoration: none;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }

  .site-header.light .lang a {
    color: var(--body-muted);
  }

  .lang a.active {
    color: var(--coral);
  }

  .lang a:hover,
  .lang a:focus-visible {
    color: var(--white);
  }

  .site-header.light .lang a:hover,
  .site-header.light .lang a:focus-visible {
    color: var(--navy);
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0.65rem 1.1rem;
    border-radius: 6px;
    background: var(--navy);
    color: var(--white);
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s;
  }

  .site-header.dark .nav-cta {
    background: var(--white);
    color: var(--navy);
  }

  .nav-cta:hover {
    background: var(--button-red);
    color: var(--white);
  }

  .site-header.dark .nav-cta:hover {
    background: var(--coral);
    color: var(--white);
  }

  /* Logo-style coral dot menu control (mobile) */
  .menu-dot {
    display: none;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
  }

  .menu-dot-core {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 50%;
    background: var(--coral);
    box-shadow: 0 0 0 0 rgba(242, 107, 94, 0.35);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .site-header.is-menu-open .menu-dot-core {
    transform: scale(1.15);
    box-shadow: 0 0 0 6px rgba(242, 107, 94, 0.18);
  }

  .menu-panel {
    display: none;
    position: absolute;
    inset: 100% 0 auto 0;
    z-index: 30;
    max-height: min(80vh, 36rem);
    overflow-y: auto;
    padding: 0.75rem var(--page-inline) 1.25rem;
    background: rgba(15, 44, 76, 0.97);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.25);
  }

  .site-header.light .menu-panel {
    background: rgba(247, 244, 241, 0.98);
    border-bottom-color: rgba(15, 44, 76, 0.1);
    box-shadow: 0 16px 36px rgba(15, 44, 76, 0.1);
  }

  .menu-panel.is-open {
    display: block;
  }

  .menu-panel-nav {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    width: min(var(--page-max), 100%);
    margin-inline: auto;
  }

  .menu-panel-label {
    margin: 0.85rem 0 0.35rem;
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--coral);
  }

  .menu-panel-link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    min-height: 44px;
    color: var(--secondary-dark);
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 0.9375rem;
  }

  .site-header.light .menu-panel-link {
    color: var(--navy);
  }

  .menu-panel-link.is-service {
    color: rgba(183, 196, 209, 0.95);
    font-size: 0.875rem;
    padding-left: 0.15rem;
  }

  .site-header.light .menu-panel-link.is-service {
    color: var(--body-muted);
  }

  .menu-panel-link.active {
    color: var(--white);
  }

  .site-header.light .menu-panel-link.active {
    color: var(--navy);
  }

  .menu-panel-lang {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: 0.85rem;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
  }

  .menu-panel-lang span {
    color: rgba(140, 160, 180, 0.5);
  }

  .menu-panel-lang a {
    color: var(--secondary-dark);
    text-decoration: none;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }

  .site-header.light .menu-panel-lang a {
