---
import Wordmark from './Wordmark.astro';
import { localePath, type Messages } from '../i18n';
import { services, servicePath } from '../data/services';
import { site } from '../lib/site';

interface Props {
  locale: string;
  t: Messages;
  variant?: 'dark' | 'light';
}

const { locale, t, variant = 'dark' } = Astro.props;
const homeHref = localePath(locale, '/');
const searchHref = localePath(locale, '/search/');
const blogHref = localePath(locale, '/blog/');
const assessmentHref = `${homeHref}#assessment`;
const path = Astro.url.pathname;
const onHome = path === '/' || path === '/es' || path === '/es/';
const onBlog = path === '/blog' || path.startsWith('/blog/') || path === '/es/blog' || path.startsWith('/es/blog/');
const enHref = locale === 'es' ? path.replace(/^\/es/, '') || '/' : path;
const esHref = locale === 'es' ? path : path === '/' ? '/es/' : `/es${path}`;
const serviceLinks = services.map((service) => ({
  href: servicePath(locale, service.slug),
  title: service.title[locale as 'en' | 'es'],
  current: path.includes(`/services/${service.slug}`),
}));
---

<header class:list={['site-header', variant]} data-site-header>
  <div class="header-inner">
    <Wordmark variant={variant} href={homeHref} />

    <div class="header-search" data-header-search>
      <div class="search-pill" data-search-pill>
        <button
          type="button"
          class="search-toggle"
          data-search-toggle
          aria-label={t.nav.searchOpen}
          aria-expanded="false"
          aria-controls="site-search-input"
        >
          <svg width="17" height="17" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <circle cx="7.5" cy="7.5" r="5.5" stroke="currentColor" stroke-width="1.3"></circle>
            <line
              x1="11.6"
              y1="11.6"
              x2="16"
              y2="16"
              stroke="currentColor"
              stroke-width="1.3"
              stroke-linecap="round"></line>
          </svg>
        </button>
        <input
          id="site-search-input"
          class="search-input"
          data-search-input
          type="search"
          enterkeyhint="search"
          autocomplete="off"
          placeholder={t.nav.searchPlaceholder}
          aria-label={t.nav.searchLabel}
          aria-controls="site-search-results"
        />
      </div>

      <div
        id="site-search-results"
        class="search-results"
        data-search-results
        role="listbox"
        aria-label={t.nav.searchResults}
        hidden
      ></div>
    </div>

    <div class="header-actions">
      <div class="lang" role="group" aria-label={locale === 'es' ? 'Idioma' : 'Language'}>
        <a
          href={enHref}
          lang="en"
          hreflang="en"
          aria-current={locale === 'en' ? 'page' : undefined}
          class:list={[{ active: locale === 'en' }]}
        >
          EN
        </a>
        <span aria-hidden="true">/</span>
        <a
          href={esHref}
          lang="es"
          hreflang="es"
          aria-current={locale === 'es' ? 'page' : undefined}
          class:list={[{ active: locale === 'es' }]}
        >
          ES
        </a>
      </div>

      <button
        type="button"
        class="menu-button"
        data-menu-toggle
        aria-expanded="false"
        aria-controls="site-menu-panel"
      >
        <span class="menu-label-stack" aria-hidden="true">
          <span class="menu-txt">{t.nav.menu}</span>
          <span class="close-txt">{t.nav.close}</span>
        </span>
        <span class="visually-hidden">{t.nav.menu}</span>
      </button>
    </div>
  </div>

  <div
    class="menu-panel"
    id="site-menu-panel"
    data-menu-panel
    aria-hidden="true"
  >
    <nav class="menu-nav" aria-label={locale === 'es' ? 'Principal' : 'Primary'}>
      <div class="menu-primary">
        <a
          href={homeHref}
          class:list={['menu-link', { active: onHome }]}
          aria-current={onHome ? 'page' : undefined}
          style="--i: 0"
        >
          <span>{t.nav.home}</span>
          <span class="link-underline" aria-hidden="true"></span>
        </a>
        <a
          href={blogHref}
          class:list={['menu-link', { active: onBlog }]}
          aria-current={onBlog ? 'page' : undefined}
          style="--i: 1"
        >
          <span>{t.blog.nav}</span>
          <span class="link-underline" aria-hidden="true"></span>
        </a>
        <a
          href={assessmentHref}
          class="menu-link"
          style="--i: 2"
        >
          <span>{t.hero.cta}</span>
          <span class="link-underline" aria-hidden="true"></span>
        </a>
      </div>

      <div class="menu-services" style="--i: 3">
        <p class="menu-services-label">{t.nav.services}</p>
        <ul class="menu-services-list">
          {
            serviceLinks.map((service, index) => (
              <li style={`--i: ${4 + index}`}>
                <a
                  href={service.href}
                  class:list={['menu-service-link', { active: service.current }]}
                  aria-current={service.current ? 'page' : undefined}
                >
                  <span>{service.title}</span>
                  <span class="link-underline" aria-hidden="true"></span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="menu-contact" style={`--i: ${4 + serviceLinks.length}`}>
        <div class="menu-lang" role="group" aria-label={locale === 'es' ? 'Idioma' : 'Language'}>
          <a
            href={enHref}
            lang="en"
            hreflang="en"
            aria-current={locale === 'en' ? 'page' : undefined}
            class:list={[{ active: locale === 'en' }]}
          >
            EN
          </a>
          <span aria-hidden="true">/</span>
          <a
            href={esHref}
            lang="es"
            hreflang="es"
            aria-current={locale === 'es' ? 'page' : undefined}
            class:list={[{ active: locale === 'es' }]}
          >
            ES
          </a>
        </div>
        <a href={`mailto:${site.email}`} class="menu-meta-link">
          <span>{site.email}</span>
          <span class="link-underline" aria-hidden="true"></span>
        </a>
        <a href={`tel:${site.phone}`} class="menu-meta-link">
          <span>{site.phoneDisplay}</span>
          <span class="link-underline" aria-hidden="true"></span>
        </a>
      </div>
    </nav>
  </div>
</header>

<script define:vars={{
  searchHref,
  labels: {
    open: t.nav.searchOpen,
    close: t.nav.searchClose,
    empty: t.nav.searchEmpty,
    unavailable: t.nav.searchUnavailable,
    allResults: t.nav.searchAllResults,
    menu: t.nav.menu,
    menuClose: t.nav.close,
  },
}}>
  const root = document.querySelector('[data-header-search]');
  const pill = root?.querySelector('[data-search-pill]');
  const toggle = root?.querySelector('[data-search-toggle]');
  const input = root?.querySelector('[data-search-input]');
  const resultsEl = root?.querySelector('[data-search-results]');

  if (
    root instanceof HTMLElement &&
    pill instanceof HTMLElement &&
    toggle instanceof HTMLButtonElement &&
    input instanceof HTMLInputElement &&
    resultsEl instanceof HTMLElement
  ) {
    let open = false;
    let pagefindPromise = null;
    let requestId = 0;
    let debounceTimer = 0;

    const setOpen = (next) => {
      open = next;
      root.classList.toggle('is-open', next);
      toggle.setAttribute('aria-expanded', String(next));
      toggle.setAttribute('aria-label', next ? labels.close : labels.open);
      if (!next) {
        resultsEl.hidden = true;
        resultsEl.innerHTML = '';
      } else {
        input.focus();
      }
    };

    const loadPagefind = () => {
      if (!pagefindPromise) {
        pagefindPromise = import('/pagefind/pagefind.js')
          .then((mod) => mod)
          .catch(() => null);
      }
      return pagefindPromise;
    };

    const renderResults = (term, items, unavailable = false) => {
      if (!term) {
        resultsEl.hidden = true;
        resultsEl.innerHTML = '';
        return;
      }
      if (unavailable) {
        resultsEl.innerHTML = `<p class="search-empty">${labels.unavailable}</p>`;
        resultsEl.hidden = false;
        return;
      }
      if (!items.length) {
        resultsEl.innerHTML = `<p class="search-empty">${labels.empty.replace('{query}', term)}</p>`;
        resultsEl.hidden = false;
        return;
      }

      const links = items
        .map(
          (item) =>
            `<a href="${item.href}" role="option" class="search-result">${item.title}</a>`,
        )
        .join('');
      const more = `<a href="${searchHref}?q=${encodeURIComponent(term)}" class="search-more">${labels.allResults}</a>`;
      resultsEl.innerHTML = `${links}${more}`;
      resultsEl.hidden = false;
    };

    const runSearch = async (query) => {
      const term = query.trim();
      const id = ++requestId;
      if (!term) {
        renderResults('', []);
        return;
      }

      try {
        const pagefind = await loadPagefind();
        if (!pagefind) {
          if (id !== requestId) return;
          renderResults(term, [], true);
          return;
        }
        const search = await pagefind.search(term);
        const data = await Promise.all(search.results.slice(0, 6).map((result) => result.data()));
        if (id !== requestId) return;
        renderResults(
          term,
          data.map((item) => ({
            title: item.meta?.title || item.url,
            href: item.url,
          })),
        );
      } catch {
        if (id !== requestId) return;
        renderResults(term, [], true);
      }
    };

    toggle.addEventListener('click', () => setOpen(!open));

    input.addEventListener('input', () => {
      window.clearTimeout(debounceTimer);
      debounceTimer = window.setTimeout(() => runSearch(input.value), 160);
    });

    input.addEventListener('keydown', (event) => {
      if (event.key === 'Enter') {
        event.preventDefault();
        const term = input.value.trim();
        if (term) window.location.assign(`${searchHref}?q=${encodeURIComponent(term)}`);
      }
      if (event.key === 'Escape') setOpen(false);
    });

    document.addEventListener('pointerdown', (event) => {
      if (!open) return;
      const target = event.target;
      if (target instanceof Node && !root.contains(target)) setOpen(false);
    });
  }

  const header = document.querySelector('[data-site-header]');
  const menuToggle = header?.querySelector('[data-menu-toggle]');
  const menuPanel = header?.querySelector('[data-menu-panel]');
  const menuLabel = menuToggle?.querySelector('.visually-hidden');

  if (
    header instanceof HTMLElement &&
    menuToggle instanceof HTMLButtonElement &&
    menuPanel instanceof HTMLElement
  ) {
    const setMenuOpen = (next) => {
      header.classList.toggle('is-menu-open', next);
      menuPanel.classList.toggle('is-open', next);
      menuToggle.setAttribute('aria-expanded', String(next));
      menuPanel.setAttribute('aria-hidden', String(!next));
      document.documentElement.classList.toggle('menu-open', next);
      if (menuLabel) menuLabel.textContent = next ? labels.menuClose : labels.menu;
      if (next) {
        const first = menuPanel.querySelector('a');
        if (first instanceof HTMLElement) first.focus();
      } else {
        menuToggle.focus();
      }
    };

    menuToggle.addEventListener('click', () => {
      setMenuOpen(!header.classList.contains('is-menu-open'));
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && header.classList.contains('is-menu-open')) {
        setMenuOpen(false);
      }
    });

    document.addEventListener('pointerdown', (event) => {
      if (!header.classList.contains('is-menu-open')) return;
      const target = event.target;
      if (target instanceof Node && !header.contains(target)) setMenuOpen(false);
    });
  }
</script>

<style is:global>
  html.menu-open {
    overflow: hidden;
  }
</style>

<style>
  .site-header {
    position: relative;
    z-index: 40;
  }

  .site-header.light {
    background: var(--cream);
    border-bottom: 1px solid rgba(15, 44, 76, 0.08);
  }

  .header-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    padding: 1rem var(--page-inline);
    min-height: 4.25rem;
    position: relative;
    z-index: 2;
  }

  .header-inner > :first-child {
    justify-self: start;
  }

  .header-search {
    justify-self: center;
    position: relative;
    z-index: 30;
  }

  .header-actions {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.06em;
  }

  .lang {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }

  .lang span {
    color: rgba(140, 160, 180, 0.5);
  }

  .lang a {
    text-decoration: none;
    color: var(--secondary-dark);
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    transition: color 0.15s;
  }

  .site-header.light .lang a {
    color: var(--body-muted);
  }

  .lang a:hover,
  .lang a:focus-visible {
    color: var(--white);
  }

  .site-header.light .lang a:hover,
  .site-header.light .lang a:focus-visible {
    color: var(--navy);
  }

  .lang a.active {
    color: var(--coral);
  }

  .lang a:focus-visible {
    outline: 2px solid var(--coral);
    outline-offset: 3px;
    border-radius: 4px;
  }

  .menu-button {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: center;
    min-height: 44px;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    overflow: hidden;
    color: var(--white);
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    line-height: 1;
  }

  .site-header.light .menu-button {
    color: var(--navy);
  }

  .site-header.dark .menu-button {
    mix-blend-mode: exclusion;
  }

  .site-header.dark.is-menu-open .menu-button {
    mix-blend-mode: normal;
    color: var(--white);
  }

  .menu-button:focus-visible {
    outline: 2px solid var(--coral);
    outline-offset: 3px;
    border-radius: 4px;
  }

  .menu-label-stack {
    position: relative;
    display: grid;
    overflow: hidden;
    height: 1em;
  }

  .menu-txt,
  .close-txt {
    grid-area: 1 / 1;
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .close-txt {
    transform: translateY(-110%);
  }

  .site-header.is-menu-open .menu-txt {
    transform: translateY(110%);
  }

  .site-header.is-menu-open .close-txt {
    transform: translateY(0);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .menu-panel {
    position: absolute;
    inset: 0 0 auto 0;
    z-index: 1;
    display: none;
    padding: 5.5rem var(--page-inline) 2.25rem;
    background: rgba(15, 44, 76, 0.96);
    color: var(--white);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 28px 60px rgba(0, 0, 0, 0.28);
    max-height: min(92vh, 56rem);
    overflow-y: auto;
    transform-origin: top right;
  }

  .site-header.is-menu-open .menu-panel,
  .menu-panel.is-open {
    display: block;
    animation: menu-panel-in 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  @keyframes menu-panel-in {
    from {
      opacity: 0;
      transform: translateY(-0.75rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .site-header.light .menu-panel {
    background: rgba(247, 244, 241, 0.98);
    color: var(--navy);
    border-bottom-color: rgba(15, 44, 76, 0.08);
    box-shadow: 0 24px 50px rgba(15, 44, 76, 0.12);
  }

  .menu-nav {
    display: grid;
    grid-template-columns: minmax(10rem, 16rem) minmax(0, 1fr);
    gap: 2rem 3.5rem;
    align-items: start;
    width: min(var(--page-max), 100%);
    margin-inline: auto;
  }

  .menu-primary,
  .menu-services-list,
  .menu-contact {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.35rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .menu-link,
  .menu-service-link,
  .menu-meta-link,
  .menu-services {
    position: relative;
  }

  .site-header.is-menu-open .menu-link,
  .site-header.is-menu-open .menu-service-link,
  .site-header.is-menu-open .menu-meta-link,
  .site-header.is-menu-open .menu-services {
    animation: menu-link-in 0.45s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: calc(0.05s + var(--i, 0) * 0.045s);
  }

  @keyframes menu-link-in {
    from {
      opacity: 0;
      transform: translateY(0.7rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .menu-link,
  .menu-service-link,
  .menu-meta-link {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    text-decoration: none;
    color: inherit;
  }

  .menu-link {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 2.4vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.15;
    padding: 0.2rem 0;
  }

  .menu-services-label {
    margin: 0 0 0.75rem;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--coral);
  }

  .menu-services-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.15rem 1.75rem;
    width: 100%;
  }

  .menu-service-link,
  .menu-meta-link {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    line-height: 1.3;
    padding: 0.45rem 0;
    color: rgba(255, 255, 255, 0.86);
  }

  .site-header.light .menu-service-link,
  .site-header.light .menu-meta-link {
    color: var(--body-muted);
  }

  .menu-lang {
    display: none;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.06em;
  }

  .menu-lang a {
    color: inherit;
    text-decoration: none;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }

  .menu-lang a.active {
    color: var(--coral);
  }

  .menu-contact {
    grid-column: 1 / -1;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    flex-direction: row;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
  }

  .site-header.light .menu-contact {
    border-top-color: rgba(15, 44, 76, 0.1);
  }

  .link-underline {
    width: 100%;
    height: 1px;
    margin-top: 0.15rem;
    background: currentColor;
    opacity: 0.35;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.2s;
  }

  .menu-link:hover .link-underline,
  .menu-link:focus-visible .link-underline,
  .menu-service-link:hover .link-underline,
  .menu-service-link:focus-visible .link-underline,
  .menu-meta-link:hover .link-underline,
  .menu-meta-link:focus-visible .link-underline,
  .menu-link.active .link-underline,
  .menu-service-link.active .link-underline {
    transform: scaleX(1);
    opacity: 0.7;
  }

  .menu-link.active,
  .menu-service-link.active {
    color: var(--coral);
  }

  .menu-link:focus-visible,
  .menu-service-link:focus-visible,
  .menu-meta-link:focus-visible {
    outline: 2px solid var(--coral);
    outline-offset: 4px;
    border-radius: 2px;
  }

  .search-pill {
    display: flex;
    align-items: center;
    height: 38px;
    border-radius: 19px;
    background: transparent;
    padding: 0 2px;
    transition: background 0.2s ease;
  }

  .header-search.is-open .search-pill {
    background: rgba(255, 255, 255, 0.12);
  }

  .site-header.light .header-search.is-open .search-pill {
    background: rgba(15, 44, 76, 0.06);
  }

  .search-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
    color: var(--secondary-dark);
    border-radius: 19px;
  }

  .site-header.light .search-toggle {
    color: var(--navy);
  }

  .search-toggle:hover,
  .search-toggle:focus-visible {
    color: var(--white);
  }

  .site-header.light .search-toggle:hover,
  .site-header.light .search-toggle:focus-visible {
    color: var(--coral);
  }

  .search-toggle:focus-visible {
    outline: 2px solid var(--coral);
    outline-offset: 2px;
  }

  .search-input {
    background: none;
    border: none;
    outline: none;
    color: var(--white);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    width: 0;
    padding: 0;
    opacity: 0;
    transition:
      width 0.25s ease,
      opacity 0.2s ease,
      padding 0.25s ease;
  }

  .site-header.light .search-input {
    color: var(--navy);
  }

  .search-input::placeholder {
    color: rgba(183, 196, 209, 0.8);
  }

  .site-header.light .search-input::placeholder {
    color: var(--placeholder);
  }

  .header-search.is-open .search-input {
    width: min(220px, 42vw);
    padding: 0 12px 0 4px;
    opacity: 1;
  }

  .search-input::-webkit-search-decoration,
  .search-input::-webkit-search-cancel-button {
    -webkit-appearance: none;
  }

  .search-results {
    position: absolute;
    top: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%);
    width: min(360px, 88vw);
    max-height: 360px;
    overflow-y: auto;
    background: rgba(15, 44, 76, 0.96);
