---
import Wordmark from './Wordmark.astro';
import { localePath, type Messages } from '../i18n';

interface Props {
  locale: string;
  t: Messages;
  variant?: 'dark' | 'light';
}

const { locale, t, variant = 'dark' } = Astro.props;
const homeHref = localePath(locale, '/');
const searchHref = localePath(locale, '/search/');
const blogHref = localePath(locale, '/blog/');
const path = Astro.url.pathname;
const onBlog = path === '/blog' || path.startsWith('/blog/') || path === '/es/blog' || path.startsWith('/es/blog/');
const enHref = locale === 'es' ? path.replace(/^\/es/, '') || '/' : path;
const esHref = locale === 'es' ? path : path === '/' ? '/es/' : `/es${path}`;
---

<header class:list={['site-header', variant]}>
  <div class="header-inner">
    <Wordmark variant={variant} href={homeHref} />

    <div class="header-search" data-header-search>
      <div class="search-pill" data-search-pill>
        <button
          type="button"
          class="search-toggle"
          data-search-toggle
          aria-label={t.nav.searchOpen}
          aria-expanded="false"
          aria-controls="site-search-input"
        >
          <svg width="17" height="17" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <circle cx="7.5" cy="7.5" r="5.5" stroke="currentColor" stroke-width="1.3"></circle>
            <line
              x1="11.6"
              y1="11.6"
              x2="16"
              y2="16"
              stroke="currentColor"
              stroke-width="1.3"
              stroke-linecap="round"></line>
          </svg>
        </button>
        <input
          id="site-search-input"
          class="search-input"
          data-search-input
          type="search"
          enterkeyhint="search"
          autocomplete="off"
          placeholder={t.nav.searchPlaceholder}
          aria-label={t.nav.searchLabel}
          aria-controls="site-search-results"
        />
      </div>

      <div
        id="site-search-results"
        class="search-results"
        data-search-results
        role="listbox"
        aria-label={t.nav.searchResults}
        hidden
      ></div>
    </div>

    <nav class="site-nav" aria-label={locale === 'es' ? 'Principal' : 'Primary'}>
      <a
        href={blogHref}
        class:list={['nav-link', { active: onBlog }]}
        aria-current={onBlog ? 'page' : undefined}
      >
        {t.blog.nav}
      </a>
      <div class="lang" role="group" aria-label={locale === 'es' ? 'Idioma' : 'Language'}>
        <a
          href={enHref}
          lang="en"
          hreflang="en"
          aria-current={locale === 'en' ? 'page' : undefined}
          class:list={[{ active: locale === 'en' }]}
        >
          EN
        </a>
        <span aria-hidden="true">/</span>
        <a
          href={esHref}
          lang="es"
          hreflang="es"
          aria-current={locale === 'es' ? 'page' : undefined}
          class:list={[{ active: locale === 'es' }]}
        >
          ES
        </a>
      </div>
    </nav>
  </div>
</header>

<script define:vars={{
  searchHref,
  labels: {
    open: t.nav.searchOpen,
    close: t.nav.searchClose,
    empty: t.nav.searchEmpty,
    unavailable: t.nav.searchUnavailable,
    allResults: t.nav.searchAllResults,
  },
}}>
  const root = document.querySelector('[data-header-search]');
  const pill = root?.querySelector('[data-search-pill]');
  const toggle = root?.querySelector('[data-search-toggle]');
  const input = root?.querySelector('[data-search-input]');
  const resultsEl = root?.querySelector('[data-search-results]');

  if (
    root instanceof HTMLElement &&
    pill instanceof HTMLElement &&
    toggle instanceof HTMLButtonElement &&
    input instanceof HTMLInputElement &&
    resultsEl instanceof HTMLElement
  ) {
    let open = false;
    let pagefindPromise = null;
    let requestId = 0;
    let debounceTimer = 0;

    const loadPagefind = () => {
      if (!pagefindPromise) {
        pagefindPromise = import('/pagefind/pagefind.js').catch((error) => {
          pagefindPromise = null;
          throw error;
        });
      }
      return pagefindPromise;
    };

    const setOpen = (next) => {
      open = next;
      root.classList.toggle('is-open', open);
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      toggle.setAttribute('aria-label', open ? labels.close : labels.open);
      if (open) {
        window.setTimeout(() => input.focus(), 20);
      } else {
        requestId += 1;
        input.value = '';
        resultsEl.hidden = true;
        resultsEl.innerHTML = '';
      }
    };

    const renderResults = (query, items, unavailable = false) => {
      const term = query.trim();
      if (!term) {
        resultsEl.hidden = true;
        resultsEl.innerHTML = '';
        return;
      }

      if (unavailable) {
        resultsEl.innerHTML = `<p class="search-empty">${labels.unavailable}</p>`;
        resultsEl.hidden = false;
        return;
      }

      if (!items.length) {
        resultsEl.innerHTML = `<p class="search-empty">${labels.empty.replace('{query}', term)}</p>`;
        resultsEl.hidden = false;
        return;
      }

      const links = items
        .map(
          (item) =>
            `<a href="${item.href}" role="option" class="search-result">${item.title}</a>`,
        )
        .join('');
      const more = `<a href="${searchHref}?q=${encodeURIComponent(term)}" class="search-more">${labels.allResults}</a>`;
      resultsEl.innerHTML = `${links}${more}`;
      resultsEl.hidden = false;
    };

    const runSearch = async (query) => {
      const term = query.trim();
      const id = ++requestId;
      if (!term) {
        renderResults('', []);
        return;
      }

      try {
        const pagefind = await loadPagefind();
        const search = await pagefind.search(term);
        const data = await Promise.all(search.results.slice(0, 6).map((result) => result.data()));
        if (id !== requestId) return;
        renderResults(
          term,
          data.map((item) => ({
            title: item.meta?.title || item.url,
            href: item.url,
          })),
        );
      } catch {
        if (id !== requestId) return;
        renderResults(term, [], true);
      }
    };

    toggle.addEventListener('click', () => setOpen(!open));

    input.addEventListener('input', () => {
      window.clearTimeout(debounceTimer);
      debounceTimer = window.setTimeout(() => runSearch(input.value), 160);
    });

    input.addEventListener('keydown', (event) => {
      if (event.key === 'Enter') {
        event.preventDefault();
        const term = input.value.trim();
        if (term) window.location.assign(`${searchHref}?q=${encodeURIComponent(term)}`);
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && open) {
        setOpen(false);
        toggle.focus();
      }
    });

    document.addEventListener('pointerdown', (event) => {
      if (!open) return;
      const target = event.target;
      if (target instanceof Node && !root.contains(target)) setOpen(false);
    });
  }
</script>

<style>
  .site-header {
    position: relative;
    z-index: 20;
  }

  .site-header.light {
    background: var(--cream);
    border-bottom: 1px solid rgba(15, 44, 76, 0.08);
  }

  .header-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    padding: 1rem var(--page-inline);
    min-height: 4.25rem;
  }

  .header-inner > :first-child {
    justify-self: start;
  }

  .header-search {
    justify-self: center;
    position: relative;
    z-index: 30;
  }

  .site-nav {
    justify-self: end;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.85rem 1rem;
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.06em;
  }

  .site-nav a {
    text-decoration: none;
    color: var(--secondary-dark);
    transition: color 0.15s;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0;
  }

  .site-header.light .site-nav a {
    color: var(--body-muted);
  }

  .site-nav a:hover,
  .site-nav a:focus-visible {
    color: var(--white);
  }

  .site-header.light .site-nav a:hover,
  .site-header.light .site-nav a:focus-visible {
    color: var(--navy);
  }

  .site-nav a:focus-visible {
    outline: 2px solid var(--coral);
    outline-offset: 3px;
    border-radius: 4px;
  }

  .lang {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }

  .lang span {
    color: rgba(140, 160, 180, 0.5);
  }

  .lang a.active {
    color: var(--coral);
  }

  .nav-link.active {
    color: var(--coral);
  }

  .site-header.light .nav-link.active {
    color: var(--coral);
  }

  .search-pill {
    display: flex;
    align-items: center;
    height: 38px;
    border-radius: 19px;
    background: transparent;
    padding: 0 2px;
    transition: background 0.2s ease;
  }

  .header-search.is-open .search-pill {
    background: rgba(255, 255, 255, 0.12);
  }

  .site-header.light .header-search.is-open .search-pill {
    background: rgba(15, 44, 76, 0.06);
  }

  .search-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
    color: var(--secondary-dark);
    border-radius: 19px;
  }

  .site-header.light .search-toggle {
    color: var(--navy);
  }

  .search-toggle:hover,
  .search-toggle:focus-visible {
    color: var(--white);
  }

  .site-header.light .search-toggle:hover,
  .site-header.light .search-toggle:focus-visible {
    color: var(--coral);
  }

  .search-toggle:focus-visible {
    outline: 2px solid var(--coral);
    outline-offset: 2px;
  }

  .search-input {
    background: none;
    border: none;
    outline: none;
    color: var(--white);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    width: 0;
    padding: 0;
    opacity: 0;
    transition:
      width 0.25s ease,
      opacity 0.2s ease,
      padding 0.25s ease;
  }

  .site-header.light .search-input {
    color: var(--navy);
  }

  .search-input::placeholder {
    color: rgba(183, 196, 209, 0.8);
  }

  .site-header.light .search-input::placeholder {
    color: var(--placeholder);
  }

  .header-search.is-open .search-input {
    width: min(220px, 42vw);
    padding: 0 12px 0 4px;
    opacity: 1;
  }

  .search-input::-webkit-search-decoration,
  .search-input::-webkit-search-cancel-button {
    -webkit-appearance: none;
  }

  .search-results {
    position: absolute;
    top: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%);
    width: min(360px, 88vw);
    max-height: 360px;
    overflow-y: auto;
    background: rgba(15, 44, 76, 0.96);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 10px;
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.35);
    padding: 6px;
    z-index: 40;
  }

  .site-header.light .search-results {
    background: rgba(255, 255, 255, 0.98);
    border-color: rgba(15, 44, 76, 0.12);
    box-shadow: 0 18px 40px rgba(15, 44, 76, 0.16);
  }

  .search-result,
  .search-more,
  .search-empty {
    display: block;
    padding: 0.7rem 0.85rem;
    font-size: 0.9375rem;
    color: var(--secondary-dark);
    text-decoration: none;
    border-radius: 6px;
    margin: 0;
  }

  .site-header.light .search-result,
  .site-header.light .search-more,
  .site-header.light .search-empty {
    color: var(--navy);
  }

  .search-result:hover,
  .search-result:focus-visible,
  .search-more:hover,
  .search-more:focus-visible {
    background: rgba(255, 255, 255, 0.1);
    color: var(--white);
    outline: none;
  }

  .site-header.light .search-result:hover,
  .site-header.light .search-result:focus-visible,
  .site-header.light .search-more:hover,
  .site-header.light .search-more:focus-visible {
    background: rgba(15, 44, 76, 0.06);
    color: var(--navy);
  }

  .search-more {
    color: var(--coral);
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .search-empty {
    font-style: italic;
    color: var(--muted-blue);
  }

  .site-header.light .search-empty {
    color: var(--body-muted);
  }

  @media (max-width: 720px) {
    .header-inner {
      grid-template-columns: auto 1fr auto;
      gap: 0.65rem;
    }

    .header-search {
      justify-self: end;
    }

    .site-nav {
      gap: 0.65rem;
    }

    .header-search.is-open .search-input {
      width: min(160px, 36vw);
    }
  }
</style>
