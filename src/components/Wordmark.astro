---
interface Props {
  variant?: 'dark' | 'light';
  href?: string;
}

const { variant = 'dark', href = '/' } = Astro.props;
---

<a href={href} class:list={['wordmark', variant]} aria-label="Cybercon Solutions home">
  <img
    src="/favicon.svg"
    alt=""
    width="32"
    height="32"
    class="mark"
    decoding="async"
  />
  <span class="lockup" aria-hidden="true">
    <span class="name">CYBERCON</span>
    <span class="sub">SOLUTIONS</span>
  </span>
</a>

<style>
  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }

  .wordmark:focus-visible {
    outline: 2px solid var(--coral);
    outline-offset: 4px;
    border-radius: 4px;
  }

  .mark {
    width: 28px;
    height: 28px;
    border-radius: 6px;
    flex-shrink: 0;
  }

  .lockup {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35em;
  }

  .name,
  .sub {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.3125rem;
    letter-spacing: 0.02em;
    line-height: 1;
  }

  .wordmark.dark .name {
    color: var(--white);
  }

  .wordmark.dark .sub {
    color: var(--muted-blue);
  }

  .wordmark.light .name {
    color: var(--navy);
  }

  .wordmark.light .sub {
    color: var(--muted-blue);
  }
</style>
