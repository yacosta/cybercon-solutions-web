# Environment variables for local development
# Copy to `.env` and fill in values. For production, set these in
# Cloudflare Workers → cybercon-solutions-web → Settings → Variables and Secrets.

# Site
PUBLIC_SITE_URL=https://cybercon-solutions.com

# Cloudflare Turnstile (form bot protection)
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Form delivery (Web3Forms) — optional email alert; Attio can be the primary CRM sink
WEB3FORMS_ACCESS_KEY=

# Attio CRM — assessment form upserts People (+ Companies) as prospects
# Create an API token in Attio → Workspace settings → Developers
# Scopes: record_permission:read-write, object_configuration:read, note:read-write
# Optional list scope: list_entry:read-write, list_configuration:read
ATTIO_API_KEY=
# Optional: Attio list ID/slug to add every prospect into (People list)
ATTIO_PROSPECTS_LIST_ID=

# Optional Google Analytics (loaded only after cookie consent = accept)
PUBLIC_GA_MEASUREMENT_ID=

# Auth0 (client area)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_BASE_URL=http://localhost:4321
AUTH0_AUDIENCE=

# Signed session cookie for client area (use a long random string)
SESSION_SECRET=replace-with-a-long-random-secret
